# CreditScope Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Model Configuration
# =============================================================================
MODEL_PATH=Qwen/Qwen3.5-35B-A3B-FP8
CONTEXT_LENGTH=32768
TP_SIZE=1
MEM_FRACTION_STATIC=0.85

# HuggingFace token for gated models (optional)
HUGGING_FACE_HUB_TOKEN=

# Model cache directory
MODEL_CACHE_DIR=~/.cache/huggingface

# =============================================================================
# Server Ports
# =============================================================================
SGLANG_PORT=8000
BACKEND_PORT=8080
FRONTEND_PORT=3000

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=sqlite:///./data/creditscope.db
SEED_DB=true

# =============================================================================
# Observability
# =============================================================================
LOG_LEVEL=INFO
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Grafana admin password
GRAFANA_PASSWORD=admin

# =============================================================================
# Thinking Budget Defaults
# =============================================================================
# Presets: none(0), minimal(128), short(512), standard(2048), 
#          extended(8192), deep(32768), unlimited(-1)
DEFAULT_THINKING_BUDGET=standard

# =============================================================================
# CORS (for development)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Production Settings (uncomment for production)
# =============================================================================
# CORS_ORIGINS=https://yourdomain.com
# LOG_LEVEL=WARNING
# SEED_DB=false
