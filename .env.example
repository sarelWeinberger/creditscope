# CreditScope Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Model Configuration
# =============================================================================
MODEL_PATH=Qwen/Qwen3.5-35B-A3B-FP8
CONTEXT_LENGTH=4096
TP_SIZE=1
MEM_FRACTION_STATIC=0.98
INFERENCE_PROFILE=stable
ENABLE_MULTIMODAL_IMAGE_INPUT=false
PYTORCH_ALLOC_CONF=expandable_segments:True
SGLANG_EXTRA_ARGS="--max-mamba-cache-size 16 --disable-cuda-graph --chunked-prefill-size 512 --max-running-requests 2 --max-total-tokens 65536 --attention-backend triton --skip-server-warmup --fp8-gemm-backend triton"
SGLANG_EXTRA_ARGS_STABLE="--max-mamba-cache-size 16 --disable-cuda-graph --chunked-prefill-size 512 --max-running-requests 2 --max-total-tokens 65536 --attention-backend triton --skip-server-warmup --fp8-gemm-backend triton"
SGLANG_EXTRA_ARGS_FAST="--max-mamba-cache-size 16 --disable-cuda-graph --chunked-prefill-size 512 --max-running-requests 2 --max-total-tokens 65536 --attention-backend triton --skip-server-warmup --fp8-gemm-backend triton"
CHAT_MAX_TOKENS=256
CHAT_MAX_TOKENS_STABLE=512
CHAT_MAX_TOKENS_FAST=256
DEFAULT_THINKING_BUDGET=standard
DEFAULT_THINKING_BUDGET_STABLE=standard
DEFAULT_THINKING_BUDGET_FAST=short

# HuggingFace token for gated models (optional)
HUGGING_FACE_HUB_TOKEN=

# Model cache directory
MODEL_CACHE_DIR=~/.cache/huggingface

# =============================================================================
# Server Ports
# =============================================================================
SGLANG_PORT=8000
BACKEND_PORT=8080
FRONTEND_PORT=3000

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=sqlite:///./data/creditscope.db
SEED_DB=true

# =============================================================================
# Observability
# =============================================================================
LOG_LEVEL=INFO
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Grafana admin password
GRAFANA_PASSWORD=admin

# Frontend basic auth for public deployments
BASIC_AUTH_USERS=user@example.com
BASIC_AUTH_PASSWORD=change-me

# Application authentication
AUTH_USERS=user@example.com
AUTH_PASSWORD=change-me
AUTH_SECRET_KEY=replace-with-a-random-secret
AUTH_SESSION_MAX_AGE_SECONDS=43200
AUTH_COOKIE_SECURE=false

# =============================================================================
# CORS (for development)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://YOUR_SERVER_IP

# =============================================================================
# Production Settings (uncomment for production)
# =============================================================================
# CORS_ORIGINS=https://yourdomain.com
# LOG_LEVEL=WARNING
# SEED_DB=false
# AUTH_COOKIE_SECURE=true
